{
    "openapi": "3.0.0",
    "info": {
        "title": "Room Catalog Service API",
        "description": "Service Katalog & Kamar - Smart Hospitality IAE Kelompok 11",
        "contact": {
            "email": "admin@hotel.com"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Room Catalog Service"
        }
    ],
    "paths": {
        "/api/v1/rooms": {
            "get": {
                "tags": [
                    "Rooms"
                ],
                "summary": "Mengambil daftar seluruh kamar",
                "operationId": "8621bf9d381104070fb98293d57bc3c2",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Filter berdasarkan status kamar",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "available",
                                "occupied",
                                "maintenance"
                            ]
                        }
                    },
                    {
                        "name": "type",
                        "in": "query",
                        "description": "Filter berdasarkan tipe kamar",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "standard",
                                "deluxe",
                                "suite",
                                "presidential"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Daftar kamar berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Data retrieved successfully"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Room"
                                            }
                                        },
                                        "meta": {
                                            "properties": {
                                                "service_name": {
                                                    "type": "string",
                                                    "example": "Room-Catalog-Service"
                                                },
                                                "api_version": {
                                                    "type": "string",
                                                    "example": "v1"
                                                },
                                                "total": {
                                                    "type": "integer",
                                                    "example": 10
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - API Key tidak valid"
                    }
                },
                "security": [
                    {
                        "X-IAE-KEY": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Rooms"
                ],
                "summary": "Menambah data kamar baru",
                "operationId": "49058005cbeb1d687de909882996a7f7",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "room_number",
                                    "type",
                                    "floor",
                                    "capacity",
                                    "price_per_night"
                                ],
                                "properties": {
                                    "room_number": {
                                        "type": "string",
                                        "example": "101"
                                    },
                                    "type": {
                                        "type": "string",
                                        "enum": [
                                            "standard",
                                            "deluxe",
                                            "suite",
                                            "presidential"
                                        ],
                                        "example": "deluxe"
                                    },
                                    "floor": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "capacity": {
                                        "type": "integer",
                                        "example": 2
                                    },
                                    "price_per_night": {
                                        "type": "number",
                                        "example": 500000
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Kamar deluxe dengan pemandangan kolam renang"
                                    },
                                    "facilities": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "example": [
                                            "WiFi",
                                            "AC",
                                            "TV",
                                            "Mini Bar"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Kamar berhasil ditambahkan",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Room created successfully"
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/Room"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "X-IAE-KEY": []
                    }
                ]
            }
        },
        "/api/v1/rooms/{id}": {
            "get": {
                "tags": [
                    "Rooms"
                ],
                "summary": "Mengambil data spesifik kamar berdasarkan ID",
                "operationId": "cbfb744a4a46d46906c8f6aa65e0e452",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID kamar",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Data kamar berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Data retrieved successfully"
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/Room"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Kamar tidak ditemukan"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "X-IAE-KEY": []
                    }
                ]
            }
        },
        "/api/v1/rooms/{id}/status": {
            "put": {
                "tags": [
                    "Rooms"
                ],
                "summary": "Mengubah status kamar (tersedia/terisi/maintenance)",
                "operationId": "730022709fab2f4645c8499ed6c3226d",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "status"
                                ],
                                "properties": {
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "available",
                                            "occupied",
                                            "maintenance"
                                        ],
                                        "example": "occupied"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Status kamar berhasil diperbarui"
                    },
                    "404": {
                        "description": "Kamar tidak ditemukan"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "X-IAE-KEY": []
                    }
                ]
            }
        },
        "/api/v1/rooms/{id}/assign": {
            "post": {
                "tags": [
                    "Rooms"
                ],
                "summary": "Menetapkan kamar untuk tamu (assign)",
                "operationId": "af9d1fe699defbdbcac4c0c811b8a688",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "guest_name",
                                    "reservation_id"
                                ],
                                "properties": {
                                    "guest_name": {
                                        "type": "string",
                                        "example": "Budi Santoso"
                                    },
                                    "reservation_id": {
                                        "type": "string",
                                        "example": "RES-2024-001"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Kamar berhasil di-assign ke tamu"
                    },
                    "409": {
                        "description": "Kamar sudah terisi"
                    },
                    "404": {
                        "description": "Kamar tidak ditemukan"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "X-IAE-KEY": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "Room": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "room_number": {
                        "type": "string",
                        "example": "101"
                    },
                    "type": {
                        "type": "string",
                        "example": "deluxe"
                    },
                    "floor": {
                        "type": "integer",
                        "example": 1
                    },
                    "capacity": {
                        "type": "integer",
                        "example": 2
                    },
                    "price_per_night": {
                        "type": "number",
                        "example": 500000
                    },
                    "status": {
                        "type": "string",
                        "example": "available"
                    },
                    "description": {
                        "type": "string",
                        "example": "Kamar deluxe dengan view kolam renang"
                    },
                    "facilities": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "created_at": {
                        "type": "string",
                        "example": "2024-01-01T00:00:00.000000Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "example": "2024-01-01T00:00:00.000000Z"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "X-IAE-KEY": {
                "type": "apiKey",
                "name": "X-IAE-KEY",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Rooms",
            "description": "Rooms"
        }
    ]
}